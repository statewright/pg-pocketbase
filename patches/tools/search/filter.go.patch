-		whereExpr, buildErr = buildResolversExpr(r1, e.op, r2)
-	}
-
-	if buildErr != nil {
-		return "0=1"
-	}
-
-	return fmt.Sprintf(
-		"NOT EXISTS (SELECT 1 FROM (%s) {{%s}} WHERE %s)",
-		e.subQuery.Build(db, params),
-		alias,
-		whereExpr.Build(db, params),
-	)
-}
