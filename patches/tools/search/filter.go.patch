-	// "" = b OR b IS NULL
-	// "" IS NOT b AND b IS NOT NULL
-	if isLeftEmpty {
-		return dbx.NewExp(
-			fmt.Sprintf("('' %s %s %s %s %s)", equalOp, right.Identifier, concatOp, right.Identifier, nullExpr),
-			mergeParams(left.Params, right.Params),
